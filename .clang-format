BasedOnStyle: LLVM
IndentWidth: 4
BreakBeforeTernaryOperators: false
ReflowComments: false
AlignTrailingComments: Always
IncludeBlocks: Regroup
IncludeCategories:
  # fmacros.h must always be first since it defines macros that affect the
  # other includes
  - Regex:           '^"fmacros.h"'
    Priority:        -1
  - Regex:           '^"'
    Priority:        1
  - Regex:           '^<(valkey)/'
    Priority:        2
  - Regex:           '^<'
    Priority:        3
  - Regex:           '.*'
    Priority:        4
